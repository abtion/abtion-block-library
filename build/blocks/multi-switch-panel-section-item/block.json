{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "abtion-block-library/multi-switch-panel-section-item",
  "version": "1.0.0",
  "title": "Multi Switch Section Item",
  "category": "abtion-blocks",
  "parent": [
    "abtion-block-library/multi-switch-panel-section"
  ],
  "description": "A content item within a Multi Switch Panel section that is shown only when its assigned section is active.",
  "icon": "admin-page",
  "supports": {
    "interactivity": true,
    "layout": {
      "allowSwitching": true
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    }
  },
  "attributes": {
    "navigationItemId": {
      "type": "string",
      "default": ""
    }
  },
  "usesContext": [
    "abtion-block-library/activeNavId"
  ],
  "textdomain": "abtion-block-library",
  "editorScript": "file:./index.js"
}