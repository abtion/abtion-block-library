{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "abtion-block-library/multi-switch-panel-navigation",
  "version": "1.0.0",
  "title": "Multi Switch Navigation",
  "category": "abtion-blocks",
  "ancestor": [
    "abtion-block-library/multi-switch-panel"
  ],
