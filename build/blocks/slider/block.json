{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "abtion-block-library/slider",
  "version": "1.1.0",
  "title": "Slider",
  "category": "abtion-blocks",
  "icon": "media-interactive",
  "description": "Slider block for displaying content in a sliding format.",
  "example": {},
  "attributes": {
    "slidesPerViewDesktop": {
      "type": "number",
      "default": 2.5
    },
    "slidesPerViewMobile": {
      "type": "number",
      "default": 1.5
    },
    "behavior": {
      "type": "string",
      "default": "normal"
    },
    "progressBarColor": {
      "type": "string",
      "default": "#C6FA5F"
    },
    "dotActiveColor": {
      "type": "string",
      "default": "#062929"
    },
    "autoSlideDuration": {
      "type": "number"
    },
    "contentSource": {
      "type": "string",
      "default": "manual",
      "enum": [
        "manual",
        "dynamic"
      ]
    }
  },
  "supports": {
    "interactivity": true,
    "className": true,
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "align": true,
    "color": {
      "background": true,
      "text": true,
      "link": true
    }
  },
  "textdomain": "abtion-block-library",
  "editorScript": "file:./index.js",
  "style": [
    "swiper",
    "file:./style-index.css"
  ],
  "script": [
    "swiper"
  ],
  "viewScriptModule": "file:./view.js",
  "render": "file:./render.php"
}