{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "abtion-block-library/slider",
  "version": "1.0.0",
  "title": "Slider",
  "category": "abtion-blocks",
  "icon": "media-interactive",
  "description": "Slider block for displaying content in a sliding format.",
  "example": {},
  "attributes": {
    "slidesPerView": {
      "type": "number",
      "default": 2
    },
    "behavior": {
      "type": "string",
      "default": "normal"
    },
    "autoplayDelay": {
      "type": "number",
      "default": 3000
    },
    "speed": {
      "type": "number",
      "default": 6000
    },
    "pauseOnHover": {
      "type": "boolean",
      "default": true
    }
  },
  "supports": {
    "interactivity": true,
    "className": true,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "align": true,
    "color": {
      "background": true,
      "text": true,
      "link": true
    }
  },
  "textdomain": "abtion-block-library",
  "editorScript": "file:./index.js",
  "style": [
    "swiper",
    "file:./style-index.css"
  ],
  "script": [
    "swiper"
  ],
  "viewScriptModule": "file:./view.js",
  "render": "file:./render.php"
}